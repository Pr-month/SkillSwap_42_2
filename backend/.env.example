# =========================
# Server configuration
# =========================
PORT=3000
NODE_ENV=development # development, production, test

# =========================
# Database (PostgreSQL)
# =========================
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=skillswap

# =========================
# Security / Password hashing
# =========================
HASH_SALT=10

# =========================
# JWT configuration
# =========================
JWT_ACCESS_SECRET=your_access_secret
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:8080

# =========================
# Admin bootstrap credentials
# =========================
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin123

# =========================
# File upload configuration
# =========================
UPLOAD_PATH=public/uploads # test/uploads
UPLOAD_MAX_FILE_SIZE=2097152 # 2MB

# =========================
# MAIL CONFIG
# =========================
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your_email@yandex.ru
MAIL_PASSWORD=your_app_password
MAIL_FROM='"No Reply" <noreply@example.com>'
MAIL_MAX_RETRIES=3
MAIL_RETRY_DELAY_MS=1000
MAIL_CONNECTION_TIMEOUT=10000
MAIL_GREETING_TIMEOUT=5000

DISABLE_EMAILS=false

# =========================
# Yandex Oauth
# =========================
YANDEX_CLIENT_ID=your_client_id
YANDEX_CLIENT_SECRET=your_client_secret
YANDEX_REDIRECT_URI=http://localhost:3000/auth/yandex/callback

# =========================
# Google Oauth
# =========================
# https://medium.com/@flavtech/google-oauth2-authentication-with-nestjs-explained-ab585c53edec
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
